rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Par défaut : tout est interdit
    match /{document=**} {
      allow read, write: if false;
    }

    // users/{uid} — chaque utilisateur ne peut lire/écrire que son propre document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   // Le document ne doit contenir que le champ syncData
                   && request.resource.data.keys().hasOnly(['syncData'])
                   // Limiter la taille du document (max 500 KB serialisé)
                   && request.resource.size() < 500 * 1024
                   // syncData doit être un map
                   && request.resource.data.syncData is map;
    }
  }
}
